# Zerodha Kite Connect Credentials
# Get API key from: https://developers.kite.trade/
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_kite_access_token

# OpenAI API
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini         # gpt-4o-mini (cheap) | gpt-4o (smarter, costs more)

# Trading Configuration
PAPER_TRADING=true              # Set to false for live trading
MAX_CAPITAL_PER_TRADE=10000     # Max INR per trade
MAX_DAILY_LOSS=5000             # Max daily loss before halting (INR)
MAX_OPEN_POSITIONS=5            # Max simultaneous open positions
RISK_PER_TRADE_PCT=2.0          # Risk % of capital per trade

# Strategy Settings
STRATEGY=momentum               # momentum | mean_reversion | combined
UNIVERSE=NIFTY50                # NIFTY50 | NIFTY100 | custom
HOLD_PERIOD_DAYS=3              # Target hold period for swing trades

# Notification (optional)
TELEGRAM_BOT_TOKEN=             # Optional: Telegram alerts
TELEGRAM_CHAT_ID=               # Optional: Telegram chat ID
